//PAULO MURILO RODRIGUES DA SILVA

void main() {
    int contador = 1;
    int num;
    int menor = 100000000;
    Scanner input = new Scanner(System.in);

    while (contador <= 10) {
        System.out.println("Digite um número: ");
        num = input.nextInt();
        if (num < menor){
            menor = num;
        }
        contador++;
    }
    System.out.println(menor);
}
