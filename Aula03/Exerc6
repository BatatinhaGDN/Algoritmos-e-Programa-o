import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        float altura;
        double peso_ideal;
        String sexo;

        System.out.println("Você é homem ou mulher? 1 para homem, 2 para mulher");
        Scanner sc = new Scanner(System.in);
        sexo = sc.nextLine();

        if (sexo.equals("1")) {
            System.out.println("Qual sua altura em m? ");
            altura = sc.nextFloat();
            peso_ideal = (72.7 * altura) - 58;
            System.out.printf("O seu peso ideal é: %.2f ", peso_ideal);

        } else if (sexo.equals("2")) {
            System.out.println("Qual sua altura em m? ");
            altura = sc.nextFloat();
            peso_ideal = (62.1 * altura) - 44.7;
            System.out.printf("O seu peso ideal é: %.2f", peso_ideal);

        } else {
            System.out.println("Opção inválida!");
        }

        sc.close();
    }
}
