import java.util.Scanner;

public class Main {
    static void main(String[] args) {
        System.out.println("Digite um número de 1 á 7");
        Scanner sc = new Scanner(System.in);

        int num = sc.nextInt();

        switch(num){
            case 1:
                System.out.println("Você escolheu o número 1");
                System.out.println("O dia da semana correspondente é: Domingo");
                break;
            case 2:
                System.out.println("Você escolheu o número 2");
                System.out.println("O dia da semana correspondente é: Segunda-feira");
                break;
            case 3:
                System.out.println("Você escolheu o número 3");
                System.out.println("O dia da semana correspondente é: Terça-feira");
                break;
            case 4:
                System.out.println("Você escolheu o número 4");
                System.out.println("O dia da semana correspondente é: Quarta-feira");
                break;
            case 5:
                System.out.println("Você escolheu o número 5");
                System.out.println("O dia da semana correspondente é: Quinta-Feira");
                break;
            case 6:
                System.out.println("Você escolheu o número 6");
                System.out.println("O dia da semana correspondente é: Sexta-feira");
                break;
            case 7:
                System.out.println("Você escolheu o número 7");
                System.out.println("O dia da semana correspondente é: Sábado");
                break;
            default:
                System.out.println("Você escolheu um valor inválido");
        }
    }
}
